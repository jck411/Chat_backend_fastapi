# ============ LLM API KEYS ============
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ============ GOOGLE OAUTH ============
GOOGLE_OAUTH_REDIRECT_URI=https://localhost:8000/api/google-auth/callback

# ============ WEATHER API ============
ACCUWEATHER_API_KEY=your_accuweather_api_key_here
ACCUWEATHER_LOCATION_KEY=your_location_key_here

# ============ OPENAI (TTS) ============
OPENAI_API_KEY=your_openai_api_key_here

# ============ AZURE (TTS/KEYWORD) ============
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# ============ CONTEXT7 API ============
CONTEXT7_API_KEY=your_context7_api_key_here

# ============ PROXMOX DEPLOYMENT ============
PROXMOX_HOST=192.168.1.11
PROXMOX_USER=root
PROXMOX_PASSWORD=your_proxmox_password_here
PROXMOX_LXC_ID=111
PROXMOX_LXC_MCP=110
PROXMOX_LXC_IP=192.168.1.111

# ============ ECHO SHOW KIOSK ============
ECHO_SHOW_IP=192.168.1.28
FULLY_KIOSK_PASSWORD=your_fully_kiosk_password_here
FULLY_KIOSK_PORT=2323
FULLY_KIOSK_START_URL=https://192.168.1.111:8000/kiosk/  # Uses PROXMOX_LXC_IP value

# ============ AZURE KEYWORD MODEL ============
AZURE_KEYWORD_MODEL_PATH=data/keyword_models/your_keyword_model.table

# ============ IMMICH (SLIDESHOW) ============
IMMICH_URL=http://192.168.1.113:2283
IMMICH_API_KEY=your_immich_api_key_here

# ============ GOOGLE CLOUD STORAGE ============
GCS_BUCKET_NAME=your_gcs_bucket_name_here
GCP_PROJECT_ID=your_gcp_project_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# ============ SHELL CHAT ============
SHELLCHAT_SERVER=http://localhost:8000
SHELL_CHAT_PROFILE=cli-default
